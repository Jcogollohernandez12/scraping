# Copy this file to .env and fill in your values

# ── General settings ──────────────────────────────────────────────────────────
# Optional: proxy list (comma-separated or use proxies in config.yaml)
# PROXIES=http://user:pass@proxy1:8080,http://proxy2:8080

# Optional: default export format
# EXPORT_FORMAT=json

# Optional: headless mode (true/false)
# HEADLESS=true

# ── LinkedIn credentials ──────────────────────────────────────────────────────
# OPCION A — Correr login automático (lo llena solo):
#   python3 main.py linkedin-login --email tu@email.com --password tupass
#
# OPCION B — Llenar a mano:
#   Chrome: DevTools → Application → Cookies → linkedin.com → copiar li_at
#
# LINKEDIN_EMAIL=tu@email.com
# LINKEDIN_PASSWORD=tupassword
# LINKEDIN_LI_AT=AQEDARxxxxxxxxxxxxxxxxxxxxxxxx
# LINKEDIN_JSESSIONID=ajax:xxxxxxxxxxxxxxxxx

# ── Proxycurl API ─────────────────────────────────────────────────────────────
# Get your API key at https://nubela.co/proxycurl
# PROXYCURL_API_KEY=your_api_key_here
